@model TourGuide

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var getCompany = ViewBag.getCompany;
}

<div class="card mt-5 shadow">

    <div class="card-header text-white">
        <h4 class="text-center mb-0">تعديل المرشد السياحي</h4>
    </div>

    <div class="card-body">

        <form asp-action="UpdateTourGuide" method="post">

            <input type="hidden" asp-for="Id" />

            <div class="row g-3">

                <div class="col-md-6">
                    <label class="form-label">اسم المرشد</label>
                    <input asp-for="Name" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">الشركة</label>

                    <select class="form-select" name="TourCompanyId">

                        @foreach (var item in getCompany)
                        {
                            if (item.Id == Model.TourCompanyId)
                            {
                                <option value="@item.Id" selected>
                                    @item.Name
                                </option>
                            }
                            else
                            {
                                <option value="@item.Id">
                                    @item.Name
                                </option>
                            }
                        }

                    </select>

                </div>

            </div>

            <div class="row mt-4">
                <div class="col text-center">
                    <button class="btn">حفظ</button>
                </div>
            </div>

        </form>

    </div>

</div>